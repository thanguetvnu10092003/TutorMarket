{
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "functions": {
    "src/app/api/payments/webhook/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/auth/[...nextauth]/route.ts": {
      "maxDuration": 15
    }
  }
}
